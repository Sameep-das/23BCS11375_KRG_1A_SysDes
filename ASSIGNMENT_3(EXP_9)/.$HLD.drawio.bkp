        <mxCell id="6K5iTRE-kS2ZPqZ-jHbK-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="2. GET /events/&amp;lt;id&amp;gt;&amp;nbsp;&lt;div&gt;&amp;nbsp;response -&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;{&lt;/span&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div&gt;&amp;nbsp; &quot;event_id&quot;: &quot;E1&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;title&quot;: &quot;Coldplay Live&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;description&quot;: &quot;Live concert...&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;category&quot;: &quot;Concert&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;duration&quot;: 180,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;language&quot;: &quot;English&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;rating&quot;: 4.8,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;cast&quot;: [&quot;Artist A&quot;],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &quot;images&quot;: [&quot;url1&quot;, &quot;url2&quot;]&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;}&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
