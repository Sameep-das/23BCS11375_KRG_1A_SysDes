        <mxCell id="6K5iTRE-kS2ZPqZ-jHbK-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-section-id=&quot;1iqiba4&quot; data-start=&quot;211&quot; data-end=&quot;245&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;1. Functional Requirements (FRs)&lt;/font&gt;&lt;/h1&gt;&lt;ul data-start=&quot;267&quot; data-end=&quot;833&quot;&gt;&lt;li data-section-id=&quot;t1z4ne&quot; data-start=&quot;267&quot; data-end=&quot;399&quot;&gt;&lt;font&gt;&lt;strong data-start=&quot;269&quot; data-end=&quot;286&quot;&gt;Search Events&lt;/strong&gt;&lt;/font&gt;&lt;ul data-start=&quot;289&quot; data-end=&quot;399&quot;&gt;&lt;li data-section-id=&quot;11mv2hq&quot; data-start=&quot;289&quot; data-end=&quot;348&quot;&gt;&lt;font&gt;By title, city, date, category (movies, concerts, sports)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;lqgozx&quot; data-start=&quot;351&quot; data-end=&quot;399&quot;&gt;&lt;font&gt;Pagination + sorting (popularity, time, price)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1hgr4aq&quot; data-start=&quot;401&quot; data-end=&quot;591&quot;&gt;&lt;font&gt;&lt;strong data-start=&quot;403&quot; data-end=&quot;425&quot;&gt;View Event Details&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;428&quot; data-end=&quot;591&quot;&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1c445y&quot; data-start=&quot;428&quot; data-end=&quot;494&quot;&gt;&lt;font&gt;Event metadata (title, description, duration, language, ratings)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1jvtl9q&quot; data-start=&quot;497&quot; data-end=&quot;539&quot;&gt;&lt;font&gt;Venue details (location, seating layout)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;mthjby&quot; data-start=&quot;542&quot; data-end=&quot;591&