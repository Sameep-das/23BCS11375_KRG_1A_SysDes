        <mxCell id="6K5iTRE-kS2ZPqZ-jHbK-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h1 data-section-id=&quot;1kavomr&quot; data-start=&quot;840&quot; data-end=&quot;879&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;2. Non-Functional Requirements (NFRs)&lt;/font&gt;&lt;/h1&gt;&lt;h3 data-section-id=&quot;77rebi&quot; data-start=&quot;881&quot; data-end=&quot;890&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Scale&lt;/font&gt;&lt;/h3&gt;&lt;ul data-start=&quot;891&quot; data-end=&quot;988&quot;&gt;&lt;li data-section-id=&quot;llhliy&quot; data-start=&quot;891&quot; data-end=&quot;944&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;100M DAU → peak QPS could hit &lt;strong data-start=&quot;923&quot; data-end=&quot;944&quot;&gt;1–2M requests/sec&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;15oooj8&quot; data-start=&quot;945&quot; data-end=&quot;988&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Read-heavy system (~95% reads, 5% writes)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3 data-section-id=&quot;rs3r3w&quot; data-start=&quot;990&quot; data-end=&quot;1021&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Availability vs Consistency&lt;/font&gt;&lt;/h3&gt;&lt;ul data-start=&quot;1022&quot; data-end=&quot;1125&quot;&gt;&lt;li data-section-id=&quot;1qad1ul&quot; data-start=&quot;1022&quot; data-end=&quot;1077&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;strong data-start=&quot;1024&quot; data-end=&quot;1077&quot;&gt;Search &amp;amp; Browse → AP (Availability &amp;gt; Consistency)&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1bdh2v4&quot; data-start=&quot;1078&quot; data-end=&quot;1125&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;strong data-start=&quot;1080&quot; data-end=&quot;1125&quot;&gt;Booking → CP (Consistency &amp;gt; Availability)&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3 data-section-id=&quot;1w4gt8e&quot; data-start=&quot;1127&quot; data-end=&quot;1142&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Performance&lt;/font&gt;&lt;/h3&gt;&lt;ul data-start=&quot;1143&quot; data-end=&quot;1199&quot;&gt;&lt;li data-section-id=&quot;1wc7b9a&quot; data-start=&quot;1143&quot; data-end=&quot;1167&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Search latency &amp;lt; 200ms&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;17kckqq&quot; data-start=&quot;1168&quot; data-end=&quot;1199&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Booking latency &amp;lt; 2–5 seconds&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3 data-section-id=&quot;l5icra&quot; data-start=&quot;1201&quot; data-end=&quot;1216&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Reliability&lt;/font&gt;&lt;/h3&gt;&lt;ul data-start=&quot;1217&quot; data-end=&quot;1287&quot;&gt;&lt;li data-section-id=&quot;19e22mn&quot; data-start=&quot;1217&quot; data-end=&quot;1257&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;No double booking (critical invariant)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1b4wxuk&quot; data-start=&quot;1258&quot; data-end=&quot;1287&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Fault-tolerant seat locking&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3 data-section-id=&quot;6zq5lu&quot; data-start=&quot;1289&quot; data-end=&quot;1298&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Other&lt;/font&gt;&lt;/h3&gt;&lt;ul data-start=&quot;1299&quot; data-end=&quot;1364&quot;&gt;&lt;li data-section-id=&quot;ge2y89&quot; data-start